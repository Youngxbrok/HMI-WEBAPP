<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TitanControl-HMI · Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #050a0f; --panel: #0b1520; --panel2: #0f1e2e; --border: #1a3a5c;
      --accent: #00d4ff; --accent2: #ff6b35; --accent3: #7c4dff;
      --text: #c8dde8; --text-dim: #4a7a99;
      --success: #00ff88; --danger: #ff3355; --warn: #ffd700;
      --font-hud: 'Rajdhani', sans-serif;
      --font-mono: 'Share Tech Mono', monospace;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); font-family: var(--font-hud); color: var(--text); min-height: 100vh; overflow-x: hidden; }
    body::before {
      content: ''; position: fixed; inset: 0;
      background-image: linear-gradient(rgba(0,212,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,.03) 1px, transparent 1px);
      background-size: 40px 40px; pointer-events: none;
    }
    .scanlines { position: fixed; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.08) 2px, rgba(0,0,0,.08) 4px); pointer-events: none; z-index: 1000; }

    /* ── TOP NAVIGATION BAR ── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 56px;
      background: rgba(5,10,15,.95);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; padding: 0 24px; gap: 20px;
      backdrop-filter: blur(10px);
    }
    .topbar-logo { font-size: 18px; font-weight: 700; letter-spacing: 3px; white-space: nowrap; }
    .topbar-logo span { color: var(--accent); }
    .topbar-sep { width: 1px; height: 28px; background: var(--border); }
    .topbar-time { font-family: var(--font-mono); font-size: 13px; color: var(--accent); }
    .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 16px; }
    .topbar-user { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); }
    .topbar-user strong { color: var(--accent); }
    .topbar-badge {
      padding: 3px 10px; font-size: 10px; font-weight: 700; letter-spacing: 2px;
      border: 1px solid var(--success); color: var(--success); background: rgba(0,255,136,.08);
    }
    .btn-logout {
      padding: 6px 16px; background: transparent; border: 1px solid var(--danger);
      color: var(--danger); font-family: var(--font-hud); font-size: 12px;
      font-weight: 700; letter-spacing: 2px; cursor: pointer; transition: all .2s;
    }
    .btn-logout:hover { background: var(--danger); color: #fff; }

    /* ── STATUS STRIP ── */
    .status-strip {
      position: fixed; top: 56px; left: 0; right: 0; z-index: 199;
      height: 28px;
      background: rgba(0,212,255,.04);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; padding: 0 24px; gap: 24px;
      overflow: hidden;
    }
    .status-item { display: flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); letter-spacing: 1px; white-space: nowrap; }
    .status-dot { width: 5px; height: 5px; border-radius: 50%; }
    .s-green { background: var(--success); box-shadow: 0 0 4px var(--success); animation: pulse 2s infinite; }
    .s-yellow { background: var(--warn); }
    .s-blue { background: var(--accent); }
    @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }

    /* ── MAIN LAYOUT ── */
    .main { padding: 104px 24px 24px; display: grid; grid-template-columns: 1fr 380px; gap: 20px; }

    /* ── PANELS ── */
    .card {
      background: var(--panel); border: 1px solid var(--border);
      clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
    }
    .card-header {
      padding: 10px 16px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(0,0,0,.2);
    }
    .card-title { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; display: flex; align-items: center; gap: 8px; }
    .card-title .dot { width: 6px; height: 6px; border-radius: 50%; }
    .card-body { padding: 16px; }

    /* ── LEFT COLUMN ── */
    .left-col { display: flex; flex-direction: column; gap: 20px; }

    /* Metrics row */
    .metrics-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .metric {
      background: var(--panel); border: 1px solid var(--border); padding: 14px 16px;
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
      position: relative; overflow: hidden;
    }
    .metric::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
    .metric.m-blue::before  { background: var(--accent); }
    .metric.m-green::before { background: var(--success); }
    .metric.m-orange::before { background: var(--accent2); }
    .metric.m-purple::before { background: var(--accent3); }
    .metric-label { font-family: var(--font-mono); font-size: 9px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
    .metric-value { font-size: 28px; font-weight: 700; line-height: 1; }
    .metric-unit { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-top: 4px; }
    .m-blue .metric-value  { color: var(--accent); }
    .m-green .metric-value { color: var(--success); }
    .m-orange .metric-value { color: var(--accent2); }
    .m-purple .metric-value { color: var(--accent3); }

    /* Voice command section */
    .voice-section { flex: 1; }
    .mic-btn-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
    .mic-btn {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 20px; background: transparent; cursor: pointer;
      border: 1px solid var(--accent2); color: var(--accent2);
      font-family: var(--font-hud); font-size: 12px; font-weight: 700; letter-spacing: 2px;
      transition: all .2s; clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    }
    .mic-btn:hover { background: rgba(255,107,53,.15); }
    .mic-btn.recording { border-color: var(--danger); color: var(--danger); animation: borderPulse 1s infinite; }
    @keyframes borderPulse { 0%,100%{box-shadow:none} 50%{box-shadow:0 0 12px rgba(255,51,85,.5)} }
    .mic-icon { font-size: 16px; }

    .transcript-box {
      background: rgba(0,0,0,.3); border: 1px solid var(--border); padding: 14px;
      min-height: 120px; font-family: var(--font-mono); font-size: 13px; line-height: 1.8;
      color: var(--text); position: relative;
    }
    .transcript-box .placeholder { color: var(--text-dim); font-size: 12px; }

    /* Command log table */
    .cmd-log { max-height: 180px; overflow-y: auto; }
    .cmd-log::-webkit-scrollbar { width: 4px; }
    .cmd-log::-webkit-scrollbar-track { background: var(--border); }
    .cmd-log::-webkit-scrollbar-thumb { background: var(--accent); }
    .log-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid rgba(26,58,92,.5); font-family: var(--font-mono); font-size: 11px; }
    .log-time { color: var(--text-dim); min-width: 56px; }
    .log-type { padding: 1px 6px; font-size: 9px; font-weight: 700; letter-spacing: 1px; min-width: 80px; text-align: center; }
    .type-voice  { background: rgba(255,107,53,.15); color: var(--accent2); border: 1px solid rgba(255,107,53,.3); }
    .type-stop   { background: rgba(255,51,85,.15);  color: var(--danger);  border: 1px solid rgba(255,51,85,.3); }
    .type-login  { background: rgba(0,212,255,.1);   color: var(--accent);  border: 1px solid rgba(0,212,255,.2); }
    .type-bio    { background: rgba(0,255,136,.1);   color: var(--success); border: 1px solid rgba(0,255,136,.2); }
    .type-other  { background: rgba(255,255,255,.05); color: var(--text-dim); border: 1px solid var(--border); }
    .log-detail { color: var(--text); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ── RIGHT COLUMN ── */
    .right-col { display: flex; flex-direction: column; gap: 20px; }

    /* Emergency Stop */
    .estop-panel {
      background: var(--panel); border: 1px solid rgba(255,51,85,.4);
      padding: 24px; text-align: center;
      clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
      box-shadow: 0 0 20px rgba(255,51,85,.1);
    }
    .estop-label { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); letter-spacing: 3px; margin-bottom: 16px; }
    .estop-btn {
      width: 140px; height: 140px; border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #ff6680, var(--danger) 60%, #800020);
      border: 4px solid #ff5566;
      box-shadow: 0 0 0 6px rgba(255,51,85,.15), 0 0 0 12px rgba(255,51,85,.08), 0 8px 24px rgba(0,0,0,.5);
      color: #fff; font-family: var(--font-hud); font-size: 13px; font-weight: 700;
      letter-spacing: 1px; text-transform: uppercase; cursor: pointer;
      transition: all .15s; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 4px; margin: 0 auto;
    }
    .estop-btn:hover { transform: scale(1.05); box-shadow: 0 0 0 6px rgba(255,51,85,.3), 0 0 0 12px rgba(255,51,85,.15), 0 0 40px rgba(255,51,85,.4); }
    .estop-btn:active { transform: scale(.95); }
    .estop-icon { font-size: 32px; }
    .estop-status { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); letter-spacing: 2px; margin-top: 14px; }

    /* System info */
    .sys-info-list { display: flex; flex-direction: column; gap: 8px; }
    .sys-row { display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: 11px; padding: 6px 0; border-bottom: 1px solid rgba(26,58,92,.5); }
    .sys-key { color: var(--text-dim); }
    .sys-val { color: var(--accent); }

    /* Mini waveform */
    .mini-wave { display: flex; align-items: center; gap: 2px; height: 20px; }
    .mini-bar { width: 3px; background: var(--accent2); border-radius: 1px; opacity: .7; }

    /* ── EMERGENCY MODAL ── */
    .emergency-modal {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,.9); align-items: center; justify-content: center;
    }
    .emergency-modal.show { display: flex; }
    .em-box {
      background: #0a0000; border: 2px solid var(--danger); padding: 40px 56px; text-align: center;
      box-shadow: 0 0 60px rgba(255,51,85,.5); animation: emergencyIn .3s ease;
      clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    }
    @keyframes emergencyIn { from{transform:scale(1.1);opacity:0} to{transform:scale(1);opacity:1} }
    .em-icon { font-size: 56px; margin-bottom: 12px; animation: warnFlash 1s step-end infinite; }
    @keyframes warnFlash { 0%,100%{opacity:1} 50%{opacity:.3} }
    .em-title { font-size: 36px; font-weight: 700; letter-spacing: 6px; color: var(--danger); margin-bottom: 8px; }
    .em-sub { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); letter-spacing: 2px; margin-bottom: 28px; }
    .em-close {
      padding: 12px 32px; background: transparent; border: 1px solid var(--text-dim);
      color: var(--text-dim); font-family: var(--font-hud); font-size: 13px; font-weight: 600;
      letter-spacing: 2px; cursor: pointer; transition: all .2s;
    }
    .em-close:hover { border-color: var(--accent); color: var(--accent); }
  </style>
</head>
<body>
<div class="scanlines"></div>

<!-- Emergency modal -->
<div class="emergency-modal" id="emergencyModal">
  <div class="em-box">
    <div class="em-icon">⚠</div>
    <div class="em-title">PARADA DE EMERGENCIA</div>
    <div class="em-sub">SISTEMA DETENIDO · TODOS LOS EQUIPOS EN MODO SEGURO</div>
    <div class="em-sub" style="color:var(--warn);margin-bottom:20px" id="emTimestamp"></div>
    <button class="em-close" onclick="document.getElementById('emergencyModal').classList.remove('show')">RECONOCER ALARMA</button>
  </div>
</div>

<!-- Top bar -->
<div class="topbar">
  <div class="topbar-logo">Titan<span>Control</span></div>
  <div class="topbar-sep"></div>
  <div class="topbar-time" id="topbarClock">--:--:--</div>
  <div class="topbar-sep"></div>
  <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);letter-spacing:2px">HMI INDUSTRIAL · PLANTA 01</span>
  <div class="topbar-right">
    <div class="topbar-user">OP: <strong><%= user.username.toUpperCase() %></strong></div>
    <div class="topbar-badge"><%= user.role.toUpperCase() %></div>
    <a href="/logout"><button class="btn-logout">SALIR</button></a>
  </div>
</div>

<!-- Status strip -->
<div class="status-strip">
  <div class="status-item"><span class="status-dot s-green"></span>MOTOR PRINCIPAL: ACTIVO</div>
  <div class="status-item"><span class="status-dot s-green"></span>HIDRÁULICO: 180 BAR</div>
  <div class="status-item"><span class="status-dot s-yellow"></span>TEMP. MOTOR: 87°C</div>
  <div class="status-item"><span class="status-dot s-blue"></span>RED CAN: OK</div>
  <div class="status-item"><span class="status-dot s-green"></span>SENSOR GPS: SEÑAL FUERTE</div>
  <div class="status-item"><span class="status-dot s-green"></span>BIOMÉTRICO: VERIFICADO</div>
</div>

<!-- Main content -->
<div class="main">
  <!-- LEFT COLUMN -->
  <div class="left-col">

    <!-- Metrics -->
    <div class="metrics-row">
      <div class="metric m-blue">
        <div class="metric-label">RPM Motor</div>
        <div class="metric-value" id="mRpm">1850</div>
        <div class="metric-unit">rev/min</div>
      </div>
      <div class="metric m-green">
        <div class="metric-label">Presión Hidráulica</div>
        <div class="metric-value" id="mHyd">182</div>
        <div class="metric-unit">bar</div>
      </div>
      <div class="metric m-orange">
        <div class="metric-label">Temperatura</div>
        <div class="metric-value" id="mTemp">87</div>
        <div class="metric-unit">°C</div>
      </div>
      <div class="metric m-purple">
        <div class="metric-label">Carga</div>
        <div class="metric-value" id="mLoad">74</div>
        <div class="metric-unit">%</div>
      </div>
    </div>

    <!-- Voice command -->
    <div class="card voice-section">
      <div class="card-header">
        <div class="card-title"><span class="dot" style="background:var(--accent2);box-shadow:0 0 4px var(--accent2)"></span>CONTROL POR VOZ — TRANSCRIPCIÓN EN TIEMPO REAL</div>
        <div class="mini-wave" id="miniWave"></div>
      </div>
      <div class="card-body">
        <div class="mic-btn-row">
          <button class="mic-btn" id="micBtn" onclick="toggleMicrophone()">
            <span class="mic-icon">🎤</span>
            <span id="micBtnLabel">ACTIVAR MICRÓFONO</span>
          </button>
          <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim)" id="micStatusLabel">Inactivo</span>
        </div>
        <div class="transcript-box" id="transcriptBox">
          <span class="placeholder">Presione "Activar Micrófono" y hable para ver la transcripción en tiempo real...</span>
        </div>
      </div>
    </div>

    <!-- Activity log -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot" style="background:var(--accent)"></span>REGISTRO DE ACTIVIDAD RECIENTE</div>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim)" id="logCount">0 eventos</span>
      </div>
      <div class="card-body">
        <div class="cmd-log" id="activityLog">
          <% logs.forEach(function(log) { %>
            <div class="log-row">
              <span class="log-time"><%= new Date(log.createdAt).toLocaleTimeString('es', {hour:'2-digit',minute:'2-digit',second:'2-digit'}) %></span>
              <span class="log-type <%= log.eventType.includes('VOICE')?'type-voice':log.eventType.includes('STOP')?'type-stop':log.eventType.includes('LOGIN')||log.eventType.includes('LOGOUT')?'type-login':log.eventType.includes('BIO')?'type-bio':'type-other' %>">
                <%= log.eventType %>
              </span>
              <span class="log-detail"><%= log.detail || '—' %></span>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div><!-- /left-col -->

  <!-- RIGHT COLUMN -->
  <div class="right-col">

    <!-- Emergency Stop -->
    <div class="estop-panel">
      <div class="estop-label">⚠ CONTROL DE EMERGENCIA</div>
      <button class="estop-btn" id="estopBtn" onclick="triggerEmergencyStop()">
        <span class="estop-icon">⏹</span>
        <span>PARADA<br>EMERGENCIA</span>
      </button>
      <div class="estop-status" id="estopStatus">SISTEMA ACTIVO — EN OPERACIÓN</div>
    </div>

    <!-- System info -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot" style="background:var(--success)"></span>ESTADO DEL SISTEMA</div>
      </div>
      <div class="card-body">
        <div class="sys-info-list">
          <div class="sys-row"><span class="sys-key">OPERARIO</span><span class="sys-val"><%= user.username %></span></div>
          <div class="sys-row"><span class="sys-key">ROL</span><span class="sys-val"><%= user.role.toUpperCase() %></span></div>
          <div class="sys-row"><span class="sys-key">ÚLTIMO LOGIN</span><span class="sys-val"><%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleString('es') : 'N/A' %></span></div>
          <div class="sys-row"><span class="sys-key">BIOMÉTRICO</span><span class="sys-val" style="color:var(--success)">VERIFICADO ✓</span></div>
          <div class="sys-row"><span class="sys-key">SESIÓN</span><span class="sys-val" id="sessionTimer">00:00</span></div>
          <div class="sys-row"><span class="sys-key">VERSIÓN HMI</span><span class="sys-val">v2.4.1</span></div>
        </div>
      </div>
    </div>

    <!-- Quick commands -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot" style="background:var(--accent3)"></span>COMANDOS RÁPIDOS</div>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:8px">
        <% ['MODO AUTOMÁTICO', 'MODO MANUAL', 'RESET SISTEMA', 'REPORTE DE TURNO'].forEach(function(cmd){ %>
          <button onclick="quickCommand('<%= cmd %>')" style="
            padding:10px 14px; background:transparent; border:1px solid var(--border);
            color:var(--text); font-family:var(--font-hud); font-size:12px; font-weight:600;
            letter-spacing:2px; cursor:pointer; text-align:left; transition:all .2s;
            clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
          " onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
             onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text)'">
            ▸ &nbsp;<%= cmd %>
          </button>
        <% }); %>
      </div>
    </div>

  </div><!-- /right-col -->
</div><!-- /main -->

<script>
  // ── Clock ───────────────────────────────────────────────────
  let sessionSeconds = 0;
  setInterval(() => {
    const now = new Date();
    document.getElementById('topbarClock').textContent = now.toLocaleTimeString('es');
    sessionSeconds++;
    const m = String(Math.floor(sessionSeconds/60)).padStart(2,'0');
    const s = String(sessionSeconds%60).padStart(2,'0');
    document.getElementById('sessionTimer').textContent = `${m}:${s}`;
  }, 1000);

  // ── Simulated metrics variation ─────────────────────────────
  function vary(base, range) { return Math.round(base + (Math.random()-.5)*range); }
  setInterval(() => {
    document.getElementById('mRpm').textContent  = vary(1850, 120);
    document.getElementById('mHyd').textContent  = vary(182, 10);
    document.getElementById('mTemp').textContent = vary(87, 4);
    document.getElementById('mLoad').textContent = vary(74, 8);
  }, 2500);

  // ── Mini waveform bars ──────────────────────────────────────
  const mw = document.getElementById('miniWave');
  for (let i = 0; i < 16; i++) {
    const b = document.createElement('div');
    b.className = 'mini-bar';
    b.style.height = (Math.random()*14 + 4) + 'px';
    mw.appendChild(b);
  }
  let waveActive = false;
  function animateMiniWave() {
    if (!waveActive) return;
    mw.querySelectorAll('.mini-bar').forEach(b => {
      b.style.height = (Math.random()*16+3) + 'px';
    });
    setTimeout(animateMiniWave, 150);
  }

  // ── Voice recognition ───────────────────────────────────────
  let recognition = null;
  let finalTranscript = '';

  function toggleMicrophone() {
    if (!recognition || !waveActive) startRecognition();
    else stopRecognition();
  }

  function startRecognition() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
      alert('Web Speech API no disponible en este navegador.\nUse Chrome o Edge.');
      return;
    }
    recognition = new SpeechRecognition();
    recognition.lang           = 'es-ES';
    recognition.continuous     = true;
    recognition.interimResults = true;

    recognition.onresult = (event) => {
      let interim = '';
      for (let i = event.resultIndex; i < event.results.length; i++) {
        const t = event.results[i][0].transcript;
        if (event.results[i].isFinal) {
          finalTranscript += t + ' ';
          logVoiceCommand(t.trim());
        } else {
          interim += t;
        }
      }
      const box = document.getElementById('transcriptBox');
      box.innerHTML =
        `<span style="color:var(--accent)">${finalTranscript}</span>` +
        `<span style="color:var(--text-dim)">${interim}</span>` +
        `<span style="display:inline-block;width:8px;height:14px;background:var(--accent);animation:blink 1s step-end infinite;vertical-align:text-bottom;margin-left:2px"></span>`;
    };

    recognition.onerror = console.warn;
    recognition.start();
    waveActive = true;
    animateMiniWave();
    document.getElementById('micBtn').classList.add('recording');
    document.getElementById('micBtnLabel').textContent = 'DETENER';
    document.getElementById('micStatusLabel').textContent = '● GRABANDO...';
    document.getElementById('micStatusLabel').style.color = 'var(--danger)';
  }

  function stopRecognition() {
    if (recognition) { recognition.stop(); recognition = null; }
    waveActive = false;
    document.getElementById('micBtn').classList.remove('recording');
    document.getElementById('micBtnLabel').textContent = 'ACTIVAR MICRÓFONO';
    document.getElementById('micStatusLabel').textContent = 'Inactivo';
    document.getElementById('micStatusLabel').style.color = 'var(--text-dim)';
    mw.querySelectorAll('.mini-bar').forEach(b => { b.style.height = (Math.random()*14+4)+'px'; });
  }

  async function logVoiceCommand(transcript) {
    await fetch('/api/voice-command', {
      method : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body   : JSON.stringify({ transcript })
    }).catch(() => {});
    addLogRow(new Date(), 'VOICE_COMMAND', transcript, 'type-voice');
  }

  // ── Emergency Stop ──────────────────────────────────────────
  let emergencyStopped = false;
  async function triggerEmergencyStop() {
    if (emergencyStopped) return;
    emergencyStopped = true;

    // Visual feedback
    document.getElementById('estopBtn').style.animation = 'emergencyFlash 1s step-end infinite';
    document.getElementById('estopStatus').textContent = '⚠ PARADA DE EMERGENCIA ACTIVADA';
    document.getElementById('estopStatus').style.color = 'var(--danger)';

    const style = document.createElement('style');
    style.textContent = `@keyframes emergencyFlash{0%,100%{box-shadow:0 0 0 6px rgba(255,51,85,.3),0 0 0 12px rgba(255,51,85,.15),0 8px 24px rgba(0,0,0,.5)}50%{box-shadow:0 0 0 10px rgba(255,51,85,.6),0 0 0 20px rgba(255,51,85,.3),0 0 60px rgba(255,51,85,.8)}}`;
    document.head.appendChild(style);

    document.getElementById('emTimestamp').textContent =
      'TIMESTAMP: ' + new Date().toLocaleString('es');
    document.getElementById('emergencyModal').classList.add('show');

    await fetch('/api/emergency-stop', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    addLogRow(new Date(), 'EMERGENCY_STOP', 'Operator triggered emergency stop', 'type-stop');
  }

  // ── Quick commands ──────────────────────────────────────────
  function quickCommand(cmd) {
    logVoiceCommand('[CMD] ' + cmd);
  }

  // ── Add log row ─────────────────────────────────────────────
  function addLogRow(date, eventType, detail, typeClass) {
    const log = document.getElementById('activityLog');
    const time = date.toLocaleTimeString('es', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
    const row = document.createElement('div');
    row.className = 'log-row';
    row.innerHTML = `
      <span class="log-time">${time}</span>
      <span class="log-type ${typeClass}">${eventType}</span>
      <span class="log-detail">${detail || '—'}</span>
    `;
    log.insertBefore(row, log.firstChild);
    const cnt = log.querySelectorAll('.log-row').length;
    document.getElementById('logCount').textContent = cnt + ' evento' + (cnt !== 1 ? 's' : '');
  }

  // ── Blink keyframe ──────────────────────────────────────────
  const blinkStyle = document.createElement('style');
  blinkStyle.textContent = `@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}`;
  document.head.appendChild(blinkStyle);

  // ── Initial log count ───────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const cnt = document.querySelectorAll('.log-row').length;
    document.getElementById('logCount').textContent = cnt + ' evento' + (cnt !== 1 ? 's' : '');
  });
</script>
</body>
</html>
